# ── Admin credentials ─────────────────────────────────────────
# The email and password used to log in to the admin panel.
# ADMIN_PASSWORD also acts as the HMAC key for session tokens —
# rotating it immediately invalidates all active sessions.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-strong-password

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Found in: Supabase dashboard → Project Settings → API → publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# ── Cloudflare Turnstile ──────────────────────────────────────
# Found in: Cloudflare dashboard → Turnstile → your site
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x000000000000000000000000
TURNSTILE_SECRET_KEY=0x000000000000000000000000000000000000000000

# ── GitHub ────────────────────────────────────────────────────
# Found in: GitHub → Settings → Developer settings → Personal access tokens
# Scopes needed: repo (to create branches, commits, and pull requests)
GITHUB_TOKEN=ghp_your-personal-access-token
GITHUB_OWNER=Gray-Cup
GITHUB_REPO=farms-directory
GITHUB_BASE_BRANCH=main

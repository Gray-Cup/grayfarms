# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Found in: Supabase dashboard → Project Settings → API → service_role (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── GitHub ────────────────────────────────────────────────────
# Found in: GitHub → Settings → Developer settings → Personal access tokens
# Scopes needed: repo (to create branches, commits, and pull requests)
GITHUB_TOKEN=ghp_your-personal-access-token
GITHUB_OWNER=Gray-Cup
GITHUB_REPO=farms-directory
GITHUB_BASE_BRANCH=main
